# Скопируйте в .env и заполните

BOT_TOKEN=123456:ABC-DEF...
ADMIN_ID=123456789

# Канал: @username или -100xxxxxxxxxx (бот — админ канала)
CHANNEL_ID=@your_channel
CHANNEL_LINK=https://t.me/your_channel

# Часовой пояс для напоминаний (IANA)
TIMEZONE=Europe/Moscow

# Админ: быстрые слоты кнопками
ADMIN_SLOTS_START=10:00
ADMIN_SLOTS_END=20:00
SLOT_STEP_MINUTES=30

